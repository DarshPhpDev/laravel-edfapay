{
    "name": "darshphpdev/laravel-edfapay",
    "description": "A fluent, modern EdfaPay v2.0 payment gateway integration for Laravel.",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "DarshPhpDev\\EdfaPay\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DarshPhpDev\\EdfaPay\\EdfaPayServiceProvider"
            ],
            "aliases": {
                "EdfaPay": "DarshPhpDev\\EdfaPay\\Facades\\EdfaPay"
            }
        }
    },
    "authors": [
        {
            "name": "Mustafa Ahmed",
            "email": "mustafa.softcode@gmail.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}